classDiagram
    class Library {
        +add_book(book)
        +register_user(user)
        +create_loan(book, user, start_date, end_date)
    }

    class Book {
        +str title
        +str author
        +bool available
        +mark_as_unavailable()
        +mark_as_available()
    }

    class User {
        +str name
        +str email
    }

    class Loan {
        +str start_date
        +str end_date
        +close_loan()
    }

    Library "1" --> "0..*" Book : manages
    Library "1" --> "0..*" User : registers
    Library "1" --> "0..*" Loan : tracks
    Loan "0..*" --> "1" Book : references
    Loan "0..*" --> "1" User : references